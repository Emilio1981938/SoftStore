class Compositor:
    """Compositor de capas (picture-in-picture, overlays, etc.)"""
    
    def composite(self, background: np.ndarray, foreground: np.ndarray, position: tuple = (50, 50), alpha: float = 0.8) -> np.ndarray:
        x, y = position
        h, w = foreground.shape[:2]
        if x + w > background.shape[1] or y + h > background.shape[0]:
            return background
        
        roi = background[y:y+h, x:x+w]
        blended = cv2.addWeighted(roi, 1 - alpha, foreground, alpha, 0)
        background[y:y+h, x:x+w] = blended
        logger.info("Composición de capas aplicada")
        return background

