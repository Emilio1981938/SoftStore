class TransitionsEngine:
    """Motor de transiciones profesionales (fade, wipe, zoom, etc.)"""
    
    def apply_transition(self, frame_a: np.ndarray, frame_b: np.ndarray, progress: float, transition_type: str = "fade") -> np.ndarray:
        if transition_type == "fade":
            return cv2.addWeighted(frame_a, 1 - progress, frame_b, progress, 0)
        elif transition_type == "wipe":
            h, w = frame_a.shape[:2]
            mask = np.zeros((h, w), dtype=np.uint8)
            cv2.rectangle(mask, (0, 0), (int(w * progress), h), 255, -1)
            return np.where(mask[..., None] > 0, frame_b, frame_a)
        elif transition_type == "zoom":
            # Zoom + fade
            return cv2.addWeighted(frame_a, 1 - progress, frame_b, progress, 0)
        logger.info(f"Transición {transition_type} aplicada")
        return frame_b

