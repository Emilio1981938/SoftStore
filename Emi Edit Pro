class TimelineEngine:
    def __init__(self):
        self.track_manager = TrackManager()
        self.clip_manager = ClipManager()
        self.undo_redo = UndoRedoManager()
        self.current_time = 0.0
        self.duration = 0.0
        self.fps = 30
        logger.info("🎬 TimelineEngine inicializado - Emi Pro Timeline")

    def load_from_project(self, project: Project) -> None:
        """Carga el timeline desde el JSON guardado en la BD"""
        if project.timeline_data:
            data = project.timeline_data
            self.track_manager.load_tracks(data.get("tracks", []))
            self.duration = data.get("duration", 0.0)
            logger.info(f"Timeline cargado para proyecto {project.id}")
        else:
            self.track_manager.create_default_tracks()

    def save_to_project(self, project: Project) -> dict:
        """Guarda el estado actual del timeline"""
        data = {
            "tracks": self.track_manager.get_all_tracks(),
            "duration": self.duration,
            "current_time": self.current_time,
            "last_updated": datetime.utcnow().isoformat()
        }
        project.timeline_data = data
        return data

    def add_clip(self, track_id: str, clip_data: dict) -> dict:
        clip = self.clip_manager.create_clip(clip_data)
        self.track_manager.add_clip_to_track(track_id, clip)
        self.undo_redo.save_state(self.track_manager.get_state())
        self._update_duration()
        logger.info(f"Clip añadido en track {track_id}")
        return clip

    def move_clip(self, clip_id: str, new_track_id: str, new_start: float):
        self.track_manager.move_clip(clip_id, new_track_id, new_start)
        self.undo_redo.save_state(self.track_manager.get_state())
        self._update_duration()

    def delete_clip(self, clip_id: str):
        self.track_manager.delete_clip(clip_id)
        self.undo_redo.save_state(self.track_manager.get_state())
        self._update_duration()

    def undo(self):
        state = self.undo_redo.undo()
        if state:
            self.track_manager.load_from_state(state)

    def redo(self):
        state = self.undo_redo.redo()
        if state:
            self.track_manager.load_from_state(state)

    def _update_duration(self):
        self.duration = self.track_manager.get_total_duration()

    async def preview_frame(self, time: float) -> dict:
