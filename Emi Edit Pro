import numpy as np
from utils.logger import logger

class AudioMixer:
    def mix(self, tracks: list[np.ndarray], volumes: list[float] = None) -> np.ndarray:
        if not tracks:
            return np.array([])
        
        # Normalizar longitudes
        max_len = max(len(t) for t in tracks)
        tracks = [np.pad(t, (0, max_len - len(t))) for t in tracks]
        
        if volumes is None:
            volumes = [1.0] * len(tracks)
        
        mixed = np.zeros(max_len)
        for track, vol in zip(tracks, volumes):
            mixed += track * vol
        
        # Normalizar para evitar clipping
        mixed = np.clip(mixed / len(tracks), -1.0, 1.0)
        logger.info("🎚️ Audio mezclado correctamente")
        return mixed

