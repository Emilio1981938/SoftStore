class TrackManager:
    def __init__(self):
        self.tracks: Dict[str, dict] = {}
        self._next_track_id = 1

    def create_default_tracks(self):
        self.tracks = {
            "video_1": {"id": "video_1", "type": "video", "clips": [], "visible": True},
            "audio_1": {"id": "audio_1", "type": "audio", "clips": [], "visible": True},
            "text_1":  {"id": "text_1",  "type": "text",  "clips": [], "visible": True}
        }
        self._next_track_id = 4

    def add_track(self, track_type: str = "video"):
        track_id = f"{track_type}_{self._next_track_id}"
        self.tracks[track_id] = {
            "id": track_id,
            "type": track_type,
            "clips": [],
            "visible": True,
            "muted": False
        }
        self._next_track_id += 1
        return track_id

    def add_clip_to_track(self, track_id: str, clip: Clip):
        if track_id in self.tracks:
            self.tracks[track_id]["clips"].append(clip.to_dict())

    def move_clip(self, clip_id: str, new_track_id: str, new_start: float):
        # Buscar y mover clip entre tracks
        for track in self.tracks.values():
            for i, clip in enumerate(track["clips"]):
                if clip["id"] == clip_id:
                    clip["start"] = new_start
                    # Mover a nuevo track
                    if new_track_id != track["id"]:
                        self.tracks[new_track_id]["clips"].append(clip)
                        del track["clips"][i]
                    return

    def delete_clip(self, clip_id: str):
        for track in self.tracks.values():
            track["clips"] = [c for c in track["clips"] if c["id"] != clip_id]

    def get_all_tracks(self) -> List[dict]:
        return list(self.tracks.values())

    def get_total_duration(self) -> float:
        max_end = 0.0
        for track in self.tracks.values():
            for clip in track["clips"]:
                end = clip.get("start", 0) + clip.get("duration", 0)
                if end > max_end:
                    max_end = end
        return max_end

    def load_tracks(self, tracks_list: list):
        self.tracks = {t["id"]: t for t in tracks_list}

    def load_from_state(self, state: dict):
        self.tracks = state.get("tracks", {})

