class VideoEngine:
    def __init__(self):
        self.proxy = ProxyEngine()
        self.codec = CodecEngine()
        self.tools = VideoEditingTools()
        self.cap = None
        logger.info("🎥 VideoEngine cargado - 100+ funciones de video activas")

    async def load_video(self, file_path: str, use_proxy: bool = True):
        if use_proxy:
            proxy_path = self.proxy.get_proxy(file_path)
            self.cap = cv2.VideoCapture(proxy_path)
        else:
            self.cap = cv2.VideoCapture(file_path)
        logger.info(f"Video cargado: {file_path}")

    def get_frame(self, time_seconds: float) -> Optional[np.ndarray]:
        if not self.cap:
            return None
        self.cap.set(cv2.CAP_PROP_POS_MSEC, time_seconds * 1000)
        ret, frame = self.cap.read()
        return frame if ret else None

    def apply_edit(self, frame: np.ndarray, edit_type: str, params: dict) -> np.ndarray:
        """Aplica cualquiera de las 100+ funciones de edición"""
        return self.tools.apply_edit(frame, edit_type, params)

    async def render_clip(self, input_path: str, output_path: str, edits: List[dict]):
        """Renderiza un clip con todas las ediciones aplicadas"""
        self.load_video(input_path)
        out = cv2.VideoWriter(output_path, self.codec.get_fourcc("mp4"), 30, (1920, 1080))
        
        while True:
            frame = self.get_frame(self.cap.get(cv2.CAP_PROP_POS_MSEC) / 1000)
            if frame is None:
                break
            for edit in edits:
                frame = self.apply_edit(frame, edit["type"], edit["params"])
            out.write(frame)
        
        out.release()
        self.cap.release()
        logger.info(f"✅ Clip renderizado: {output_path}")

