class ProxyEngine:
    def __init__(self):
        self.proxy_dir = os.path.join(settings.MEDIA_DIR, "proxies")
        os.makedirs(self.proxy_dir, exist_ok=True)

    def get_proxy(self, original_path: str) -> str:
        proxy_name = os.path.basename(original_path).replace(".", "_proxy.")
        proxy_path = os.path.join(self.proxy_dir, proxy_name)
        
        if not os.path.exists(proxy_path):
            logger.info(f"Creando proxy para: {original_path}")
            cmd = [
                settings.FFMPEG_PATH,
                "-i", original_path,
                "-vf", "scale=640:-1",
                "-c:v", "libx264",
                "-preset", "ultrafast",
                "-crf", "23",
                proxy_path
            ]
            subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

